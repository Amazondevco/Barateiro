# Supabase — copie para .env.local e preencha
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Server-only (NUNCA expor no client):
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# IA do agente de formulários (Groq — server-only)
GROQ_API_KEY=gsk_xxx

# APK Android de testes exibido em Configurações > Aplicativo (Super Admin)
ANDROID_APK_URL=https://seu-dominio.com/checkai.apk
ANDROID_APK_VERSION=0.1.0
