# Supabase — copie para .env.local e preencha
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Server-only (NUNCA expor no client):
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# IA do agente de formulários (Groq — server-only)
GROQ_API_KEY=gsk_xxx

# APK Android de testes exibido em Configurações > Aplicativo (Super Admin)
ANDROID_APK_URL=https://seu-dominio.com/checkai.apk
ANDROID_APK_VERSION=0.1.0

# Push (FCM HTTP v1) — server-only. JSON da service account do Firebase
# (Configurações do projeto > Contas de serviço > Gerar nova chave privada),
# colado em uma única linha. Sem isso, o push é no-op e o comunicado só
# chega pela inbox (aba Avisos) do app.
FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"checkai-c0a4d",...}
